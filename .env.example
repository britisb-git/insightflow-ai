# MongoDB Configuration
MONGO_URL=your_mongodb_atlas_connection_string_here
DB_NAME=insightflow_ai

# Application URL (will be auto-set by Vercel)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# CORS Configuration
CORS_ORIGINS=*

# OpenAI Configuration (Optional - works with fallback if not provided)
OPENAI_API_KEY=your_openai_api_key_here_optional
OPENAI_BASE_URL=https://api.openai.com/v1

# JWT Secret (Generate a random 32+ character string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_generated_jwt_secret_here_minimum_32_characters
